# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Sandbox testing (Resend free / unverified domain):
# - from MUST be exactly onboarding@resend.dev
# - to MUST be the email you used to sign up for Resend
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=your_registered_email@example.com

# After you verify a custom domain in Resend, you can use e.g.:
# EMAIL_FROM=Pinnacle Accountancy <hello@yourdomain.com>
# EMAIL_TO=hello@yourdomain.com
